    },
    "./dist/text-annotator.css": "./dist/text-annotator.css"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "@types/rbush": "^3.0.3",
    "@types/uuid": "^9.0.8",
    "jsdom": "^24.1.0",
    "svelte": "^4.2.18",
    "typescript": "^5.4.5",
    "vite": "^5.2.13",
    "vite-plugin-dts": "^3.9.1",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "@annotorious/core": "https://gitpkg.now.sh/oleksandr-danylchenko/annotorious/packages/annotorious-core?main&scripts.postinstall=npm%20install%20--ignore-scripts%20%26%26%20npm%20run%20build%20%26%26%20rm%20-rf%20node_modules%2F",
    "colord": "^2.9.3",
    "dequal": "^2.0.3",
    "rbush": "^3.0.1",
    "uuid": "^10.0.0"
  }
}
